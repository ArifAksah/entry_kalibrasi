# Port untuk PDF Template Service (range: 1024-65535, default: 8000)
PDF_SERVICE_PORT=8000

# Direktori penyimpanan file template .docx (default: ./templates/)
PDF_TEMPLATE_DIR=./templates/

# Daftar allowed CORS origins, dipisahkan koma
# Contoh: http://localhost:3000,https://yourdomain.com
PDF_CORS_ORIGINS=http://localhost:3000
